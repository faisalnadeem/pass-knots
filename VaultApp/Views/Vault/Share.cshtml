@model ShareViewModel
@{ ViewData["Title"] = "Share Entry"; }

<div class="form-page">
    <div class="form-card">
        <div class="form-card-header">
            <a asp-action="Index" class="back-link">← Vault</a>
            <h1>Share Entry</h1>
        </div>

        <div class="share-info">
            <span class="share-info-icon">🔗</span>
            <div>
                <strong>@Model.SiteName</strong>
                <p>Share by email or generate a one-time code (valid 30 days, single use).</p>
            </div>
        </div>

        <div class="share-existing">
            <h2>Already shared with</h2>
            @if (Model.SharedWith.Count == 0)
            {
                <p class="share-existing-empty">No users yet.</p>
            }
            else
            {
                <div class="share-existing-list">
                    @foreach (var recipient in Model.SharedWith)
                    {
                        <form asp-action="Unshare" method="post" class="share-existing-item">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="vaultEntryId" value="@Model.VaultEntryId" />
                            <input type="hidden" name="sharedEntryId" value="@recipient.SharedEntryId" />
                            <span>@recipient.Email</span>
                            <button type="submit" class="share-remove-btn" aria-label="Remove sharing for @recipient.Email" title="Remove sharing">×</button>
                        </form>
                    }
                </div>
            }
        </div>

        <div class="share-section">
            <h2>Share by email</h2>
            <form asp-action="Share" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="VaultEntryId" type="hidden" />
                <input asp-for="SiteName" type="hidden" />

                @{
                    var shareFormErrors = ViewData.ModelState
                        .Where(kv => kv.Value?.Errors.Count > 0)
                        .SelectMany(kv => kv.Value!.Errors.Select(e => e.ErrorMessage))
                        .Where(msg => !string.IsNullOrWhiteSpace(msg))
                        .ToList();
                }
                @if (shareFormErrors.Count > 0)
                {
                    <div class="validation-summary" role="alert">
                        @foreach (var msg in shareFormErrors)
                        {
                            <p class="validation-summary-line">@msg</p>
                        }
                    </div>
                }

                <div class="field-group">
                    <label asp-for="RecipientEmail">Recipient's Email</label>
                    <input asp-for="RecipientEmail" type="email" placeholder="friend@example.com" />
                    <span asp-validation-for="RecipientEmail" class="field-error"></span>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Share by Email</button>
                </div>
            </form>
        </div>

        <div class="share-section share-section-code">
            <h2>Share by code</h2>
            <p class="share-code-hint">
                Anyone with the code can add this entry once.
                <span class="share-code-warning">Copy the code before leaving the page.</span>
            </p>

            @if (!string.IsNullOrEmpty(Model.ActiveShareCode))
            {
                <div class="share-code-box">
                    <label class="entry-label">Active share code</label>
                    <div class="share-code-row">
                        <code id="active-share-code" class="share-code-value">@Model.ActiveShareCode</code>
                        <button type="button" class="btn btn-outline btn-sm" id="copy-share-code-btn">Copy</button>
                    </div>
                    @if (Model.ActiveShareCodeExpiresAt.HasValue)
                    {
                        <p class="share-code-expiry">Expires @Model.ActiveShareCodeExpiresAt.Value.ToLocalTime().ToString("g")</p>
                    }
                </div>
            }

            <form asp-action="GenerateShareCode" method="post" class="share-code-generate-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="vaultEntryId" value="@Model.VaultEntryId" />
                <button type="submit" class="btn btn-outline">Generate Share Code</button>
            </form>
        </div>

        <div class="form-actions share-page-footer">
            <a asp-action="Index" class="btn btn-outline">Back to Vault</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('copy-share-code-btn')?.addEventListener('click', async () => {
            const code = document.getElementById('active-share-code')?.textContent?.trim();
            if (!code) return;
            try {
                await navigator.clipboard.writeText(code);
            } catch {
                const ta = document.createElement('textarea');
                ta.value = code;
                document.body.appendChild(ta);
                ta.select();
                document.execCommand('copy');
                ta.remove();
            }
            const btn = document.getElementById('copy-share-code-btn');
            if (btn) {
                const prev = btn.textContent;
                btn.textContent = 'Copied!';
                setTimeout(() => { btn.textContent = prev; }, 1500);
            }
        });
    </script>
}
