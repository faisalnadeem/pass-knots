@model ShareViewModel
@{
    ViewData["Title"] = "Share Entry";
    var hasEmailErrors = ViewData.ModelState["RecipientEmail"]?.Errors.Count > 0;
    var defaultShareMode = hasEmailErrors == true
        ? "email"
        : (!string.IsNullOrEmpty(Model.ActiveShareCode) ? "code" : "email");
}

<div class="form-page">
    <div class="form-card">
        <div class="form-card-header">
            <a asp-action="Index" class="back-link">← Vault</a>
            <h1 class="share-page-title">
                <span class="share-page-title-leading">
                    <span>Share Entry</span>
                    <span class="info-tooltip">
                        <button type="button" class="info-tooltip-trigger" aria-describedby="share-page-info-tooltip" aria-label="How sharing works">i</button>
                        <span id="share-page-info-tooltip" class="info-tooltip-content" role="tooltip">Share by email or generate a one-time code (valid 30 days). Each code can only be used once.</span>
                    </span>
                </span>
                <span class="share-entry-name">@Model.SiteName</span>
            </h1>
        </div>

        <div class="share-existing">
            <h2>Already shared with</h2>
            @if (Model.SharedWith.Count == 0)
            {
                <p class="share-existing-empty">No users yet.</p>
            }
            else
            {
                <div class="share-existing-list">
                    @foreach (var recipient in Model.SharedWith)
                    {
                        <form asp-action="Unshare" method="post" class="share-existing-item">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="vaultEntryId" value="@Model.VaultEntryId" />
                            <input type="hidden" name="sharedEntryId" value="@recipient.SharedEntryId" />
                            <span>@recipient.Email</span>
                            <button type="submit" class="share-remove-btn" aria-label="Remove sharing for @recipient.Email" title="Remove sharing">×</button>
                        </form>
                    }
                </div>
            }
        </div>

        <div class="share-tabs">
            <div class="view-switch share-mode-switch" role="tablist" aria-label="Share method">
                <button type="button" class="view-switch-btn @(defaultShareMode == "email" ? "is-active" : null)" id="share-email-tab" data-share-mode="email" role="tab" aria-selected="@(defaultShareMode == "email" ? "true" : "false")" aria-controls="share-email-panel">Share by Email</button>
                <button type="button" class="view-switch-btn @(defaultShareMode == "code" ? "is-active" : null)" id="share-code-tab" data-share-mode="code" role="tab" aria-selected="@(defaultShareMode == "code" ? "true" : "false")" aria-controls="share-code-panel">Share by Code</button>
            </div>

            <div id="share-email-panel" class="share-tab-panel" role="tabpanel" aria-labelledby="share-email-tab" @(defaultShareMode == "code" ? "hidden" : null)>
            <form asp-action="Share" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="VaultEntryId" type="hidden" />
                <input asp-for="SiteName" type="hidden" />

                @{
                    var shareFormErrors = ViewData.ModelState
                        .Where(kv => kv.Value?.Errors.Count > 0)
                        .SelectMany(kv => kv.Value!.Errors.Select(e => e.ErrorMessage))
                        .Where(msg => !string.IsNullOrWhiteSpace(msg))
                        .ToList();
                }
                @if (shareFormErrors.Count > 0)
                {
                    <div class="validation-summary" role="alert">
                        @foreach (var msg in shareFormErrors)
                        {
                            <p class="validation-summary-line">@msg</p>
                        }
                    </div>
                }

                <div class="field-group">
                    <input asp-for="RecipientEmail" type="email" placeholder="friend@example.com" />
                    <span asp-validation-for="RecipientEmail" class="field-error"></span>
                </div>

                <div class="share-tab-actions">
                    <button type="submit" class="btn btn-outline">Share by Email</button>
                </div>
            </form>
            </div>

            <div id="share-code-panel" class="share-tab-panel" role="tabpanel" aria-labelledby="share-code-tab" @(defaultShareMode == "code" ? null : "hidden")>
            <p class="share-code-hint">
                Anyone with the code can add this entry only once.
                <span class="share-code-warning">Copy the code before leaving the page.</span>
            </p>

            @if (!string.IsNullOrEmpty(Model.ActiveShareCode))
            {
                <div class="share-code-box">
                    <label class="entry-label">Active share code</label>
                    <div class="share-code-row">
                        <code id="active-share-code" class="share-code-value">@Model.ActiveShareCode</code>
                        <button type="button" class="btn btn-outline btn-sm" id="copy-share-code-btn">Copy</button>
                    </div>
                    @if (Model.ActiveShareCodeExpiresAt.HasValue)
                    {
                        <p class="share-code-expiry">Expires @Model.ActiveShareCodeExpiresAt.Value.ToLocalTime().ToString("g")</p>
                    }
                </div>
            }

            <form asp-action="GenerateShareCode" method="post" class="share-code-generate-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="vaultEntryId" value="@Model.VaultEntryId" />
                <button type="submit" class="btn btn-outline">Generate Share Code</button>
            </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const emailTab = document.getElementById('share-email-tab');
            const codeTab = document.getElementById('share-code-tab');
            const emailPanel = document.getElementById('share-email-panel');
            const codePanel = document.getElementById('share-code-panel');
            if (!emailTab || !codeTab || !emailPanel || !codePanel) return;

            function setShareMode(mode) {
                const showCode = mode === 'code';
                emailPanel.hidden = showCode;
                codePanel.hidden = !showCode;
                emailTab.classList.toggle('is-active', !showCode);
                emailTab.setAttribute('aria-selected', showCode ? 'false' : 'true');
                codeTab.classList.toggle('is-active', showCode);
                codeTab.setAttribute('aria-selected', showCode ? 'true' : 'false');
            }

            emailTab.addEventListener('click', () => setShareMode('email'));
            codeTab.addEventListener('click', () => setShareMode('code'));
            setShareMode('@defaultShareMode');
        })();

        document.getElementById('copy-share-code-btn')?.addEventListener('click', async () => {
            const code = document.getElementById('active-share-code')?.textContent?.trim();
            if (!code) return;
            try {
                await navigator.clipboard.writeText(code);
            } catch {
                const ta = document.createElement('textarea');
                ta.value = code;
                document.body.appendChild(ta);
                ta.select();
                document.execCommand('copy');
                ta.remove();
            }
            const btn = document.getElementById('copy-share-code-btn');
            if (btn) {
                const prev = btn.textContent;
                btn.textContent = 'Copied!';
                setTimeout(() => { btn.textContent = prev; }, 1500);
            }
        });
    </script>
}
