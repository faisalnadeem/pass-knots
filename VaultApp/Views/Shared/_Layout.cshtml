<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — " : "")Pass Knots</title>
    <link rel="icon" href="~/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="~/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="noise"></div>

    <nav class="topbar">
        <a class="brand" asp-controller="@(User.Identity?.IsAuthenticated == true ? "Vault" : "Home")" asp-action="Index">
            <partial name="_SiteLogo" model="@("md")" />
            <span class="brand-text">PassKnots</span>
        </a>
        <div class="nav-actions">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <span class="nav-user">@User.Identity.Name</span>
                <a class="nav-link" asp-controller="Vault" asp-action="Index">Vault</a>
                <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="nav-link btn-ghost">Sign Out</button>
                </form>
            }
            else
            {
                <a class="nav-link" asp-controller="Account" asp-action="Login">Sign In</a>
                <a class="nav-link btn-accent" asp-controller="Account" asp-action="Register">Register</a>
            }
        </div>
    </nav>

    <div class="site-shell">
        <main class="main-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-error">@TempData["Error"]</div>
            }
            @RenderBody()
        </main>

        <footer class="site-footer">
            <div class="site-footer-inner">
                <div class="site-footer-start">
                    <span class="site-footer-brand">
                        <partial name="_SiteLogo" model="@("sm")" /> PassKnots
                    </span>
                    <p class="site-footer-credit">
                        A product by
                        <a href="https://devnetsystems.com/" target="_blank" rel="noopener noreferrer">Devnet Systems</a>
                    </p>
                </div>
                <nav class="site-footer-nav" aria-label="Footer">
                    <a asp-controller="Home" asp-action="Privacy">Privacy</a>
                    <a asp-controller="Home" asp-action="Terms">Terms of Use</a>
                </nav>
            </div>
        </footer>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
