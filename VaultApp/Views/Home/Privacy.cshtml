@{
    ViewData["Title"] = "Privacy Policy";
    Layout = "_Layout";
}

<div class="legal-page">
    <header class="legal-hero">
        <partial name="_SiteLogo" model="@("lg")" />
        <div class="hero-badge">Privacy &amp; Security</div>
        <h1 class="legal-title">Privacy Policy</h1>
        <p class="legal-intro">
            Welcome to PassKnots. Your privacy and data security are extremely important to us.
            This Privacy Policy explains how we collect, use, protect, and handle your information
            when you use our website and services.
        </p>
    </header>

    <div class="legal-sections">
        <section class="legal-section">
            <h2 class="legal-section-title"><span class="legal-section-icon" aria-hidden="true">📋</span> Information We Collect</h2>
            <p>When you use PassKnots, we may collect the following information:</p>
            <ul class="legal-list">
                <li>Email address</li>
                <li>Account credentials</li>
                <li>Vault and password-related data entered by the user</li>
                <li>Authentication and security-related information</li>
            </ul>
            <p>This information is collected only to provide and maintain the functionality of the platform.</p>
        </section>

        <section class="legal-section">
            <h2 class="legal-section-title"><span class="legal-section-icon" aria-hidden="true">⚙️</span> How We Use Your Information</h2>
            <p>The information collected is used strictly for:</p>
            <ul class="legal-list">
                <li>Creating and managing your account</li>
                <li>Authenticating users securely</li>
                <li>Encrypting and storing vault data</li>
                <li>Providing password management and sharing features</li>
                <li>Improving platform security and performance</li>
                <li>Preventing unauthorized access and abuse</li>
            </ul>
            <p class="legal-emphasis">
                We do <strong>NOT</strong> sell, rent, trade, or share your personal information or vault data
                with third parties for advertising, marketing, or any external commercial use.
            </p>
        </section>

        <section class="legal-section">
            <h2 class="legal-section-title"><span class="legal-section-icon" aria-hidden="true">🛡️</span> Data Security</h2>
            <p>
                We take data security seriously and implement industry-standard security measures
                to protect your information.
            </p>
            <p>
                Your vault data and passwords are encrypted and protected against unauthorized access.
                We use secure authentication and encrypted communication wherever applicable.
            </p>
            <p>
                While we strive to use commercially acceptable means to protect your data,
                no method of electronic storage or transmission over the internet is 100% secure.
            </p>
        </section>

        <section class="legal-section">
            <h2 class="legal-section-title"><span class="legal-section-icon" aria-hidden="true">🔐</span> Encryption &amp; Sensitive Data</h2>
            <p>PassKnots is designed with privacy and security in mind.</p>
            <ul class="legal-list">
                <li>Encryption keys are controlled by the user</li>
                <li>Sensitive vault information is encrypted</li>
                <li>We do not expose internal security secrets publicly</li>
                <li>We do not intentionally access or misuse user vault data</li>
            </ul>
            <p>Users are responsible for keeping their login credentials and encryption keys secure.</p>
        </section>

        <section class="legal-section">
            <h2 class="legal-section-title"><span class="legal-section-icon" aria-hidden="true">🤝</span> Data Sharing</h2>
            <p>
                PassKnots does not share user data with external organizations except where required
                by law or necessary to provide core platform functionality.
            </p>
            <p>Any sharing functionality within the platform is fully controlled by the user.</p>
        </section>

        <section class="legal-section">
            <h2 class="legal-section-title"><span class="legal-section-icon" aria-hidden="true">☁️</span> Third-Party Services</h2>
            <p>
                PassKnots may use trusted infrastructure or hosting providers necessary to operate
                the platform securely. However, user data is not sold or shared for marketing purposes.
            </p>
        </section>

        <section class="legal-section">
            <h2 class="legal-section-title"><span class="legal-section-icon" aria-hidden="true">👤</span> User Responsibilities</h2>
            <p>Users are responsible for:</p>
            <ul class="legal-list">
                <li>Maintaining the confidentiality of their credentials</li>
                <li>Safeguarding encryption keys</li>
                <li>Using secure devices and networks when accessing the platform</li>
            </ul>
            <p>Loss of encryption keys may result in inability to access encrypted vault data.</p>
        </section>
    </div>
</div>
